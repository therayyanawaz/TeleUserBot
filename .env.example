# TeleUserBot - Environment Configuration Example
# Copy this file to .env and fill in the values.
# Do NOT commit your .env file to source control.
# Runtime logs are written to ~/.tg_userbot/runtime.log and ~/.tg_userbot/errors.log.
# Both files reset on every python main.py start and rotate at 10 MB x 5 during a run.

# -----------------------------------------------------------------------------
# 1. Telegram API Credentials (REQUIRED)
# -----------------------------------------------------------------------------
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=""

# -----------------------------------------------------------------------------
# 2. News Sources
# -----------------------------------------------------------------------------
# A folder invite link to join several channels at once
FOLDER_INVITE_LINK=""
# A list of channel IDs or usernames to monitor (e.g., ["@channel1", 12345678])
EXTRA_SOURCES=[]
# A list of channel IDs to monitor
SOURCES=[]

# -----------------------------------------------------------------------------
# 3. Destination Configuration
# -----------------------------------------------------------------------------
# Mode for destination (e.g., "bot", "saved_messages", or "channel_id")
DESTINATION=""
# If mode is "bot", provide the bot token and chat ID
BOT_DESTINATION_TOKEN=""
BOT_DESTINATION_CHAT_ID=""

# -----------------------------------------------------------------------------
# 4. AI / Codex Configuration (REQUIRED)
# -----------------------------------------------------------------------------
CODEX_BASE_URL="https://chatgpt.com/backend-api"
# Lower-usage Codex model for ChatGPT-account OAuth setups.
CODEX_MODEL="gpt-5.1-codex-mini"
CODEX_ORIGINATOR="pi"
OPENAI_AUTH_BASE="https://auth.openai.com"
# Force headless/env-only auth for cloud environments
OPENAI_AUTH_ENV_ONLY=true

# Optional auth bootstrap for cloud runtimes (Replit, etc.)
# If you have an existing session, you can paste the JSON or Base64 here:
TG_USERBOT_AUTH_JSON=""
TG_USERBOT_AUTH_JSON_B64=""

# -----------------------------------------------------------------------------
# 5. Pipeline Concurrency & Memory Management
# -----------------------------------------------------------------------------
# Critical for low-RAM VPS (like yours with 2GB and no Swap).
# Lower values prevent the Linux OOM killer from "Killing" the bot.

# Number of parallel workers for each pipeline stage
PIPELINE_TRIAGE_WORKERS=1
PIPELINE_AI_WORKERS=1
PIPELINE_QUERY_WEB_WORKERS=1

# -----------------------------------------------------------------------------
# 6. Core Behavior & Digest Settings
# -----------------------------------------------------------------------------
# Runtime timezone for query date parsing and daily scheduling.
# Use an IANA timezone name. Example for IST: Asia/Kolkata
TIMEZONE="Asia/Kolkata"

DIGEST_MODE=true
DIGEST_INTERVAL_MINUTES=30
DIGEST_DAILY_TIMES=["00:00"]

DIGEST_DAILY_WINDOW_HOURS=24
DIGEST_DAILY_MAX_POSTS=300
DIGEST_MAX_POSTS=80
DIGEST_MAX_TOKENS=18000
CODEX_MODEL_CONTEXT_TOKENS=200000
DIGEST_CONTEXT_FRACTION=0.75

DIGEST_MIN_POST_LENGTH=12
DIGEST_MAX_LINES=12
DIGEST_PREFER_JSON_OUTPUT=true
OUTPUT_LANGUAGE="English"
DIGEST_HEADLINE_CONTEXT_ENABLED=true
DIGEST_HEADLINE_CONTEXT_MAX_ITEMS=2
DIGEST_HEADLINE_CONTEXT_HOURS_BACK=168
DIGEST_HEADLINE_CONTEXT_TELEGRAM_MAX_MESSAGES=8
DIGEST_HEADLINE_CONTEXT_WEB_MAX_RESULTS=6

# -----------------------------------------------------------------------------
# 7. Deduplication & Routing
# -----------------------------------------------------------------------------
ENABLE_DUPE_DETECTION=true
DUPE_ENABLED=true
DUPE_THRESHOLD=0.87
DUPE_CACHE_SIZE=400
DUPE_HISTORY_HOURS=4
DUPE_MERGE_INSTEAD_OF_SKIP=true

# Memory Warning: Setting this to 'true' will download ~500MB model on startup.
# Keep 'false' if your RAM is <= 2GB.
DUPE_USE_SENTENCE_TRANSFORMERS=false

# How many hours to keep AI filtering decisions in local cache
AI_DECISION_CACHE_HOURS=72

ENABLE_SEVERITY_ROUTING=true
IMMEDIATE_HIGH=true
DIGEST_IMPORTANCE_SCORING=true
DIGEST_INCLUDE_READ_MORE_LINKS=false
DIGEST_SOURCE_TIERS={}
INCLUDE_SOURCE_TAGS=false

# -----------------------------------------------------------------------------
# 9. Breaking Story Detection
# -----------------------------------------------------------------------------
BREAKING_NEWS_KEYWORDS=["breaking","urgent","alert","explosion","strike","airstrike","missile","attack","casualties","killed"]
BREAKING_MATCH_THRESHOLD=1
ENABLE_BREAKING_TOPIC_THREADS=true
BREAKING_TOPIC_WINDOW_MINUTES=180
BREAKING_TOPIC_MIN_OVERLAP=2
BREAKING_TOPIC_MIN_RATIO=0.55

# -----------------------------------------------------------------------------
# 10. Query Assistant Mode (Private Chat)
# -----------------------------------------------------------------------------
QUERY_MODE_ENABLED=true
QUERY_MAX_MESSAGES=50
QUERY_DEFAULT_HOURS_BACK=24
QUERY_WEB_MIN_TELEGRAM_RESULTS=3
QUERY_WEB_MAX_RESULTS=12
QUERY_ALLOWED_CHAT_IDS=[]
QUERY_ALLOWED_PEER_IDS=[]

# -----------------------------------------------------------------------------
# 11. Health & Web Server
# -----------------------------------------------------------------------------
ENABLE_WEB_SERVER=true
WEB_SERVER_HOST="0.0.0.0"
WEB_SERVER_PORT=8080
# Keep process alive on startup errors so /health stays reachable (for UptimeRobot/Replit)
HOLD_ON_STARTUP_ERROR=true
DEPLOY_WEBHOOK_SECRET=""
DEPLOY_WEBHOOK_PORT=9876
DEPLOY_RESTART_CMD="systemctl restart teleuserbot"

# -----------------------------------------------------------------------------
# 12. Rendering & UX
# -----------------------------------------------------------------------------
ENABLE_HTML_FORMATTING=true
ENABLE_PREMIUM_EMOJI=true
PREMIUM_EMOJI_MAP_FILE="nezami_emoji_map.json"
STREAMING_ENABLED=true
STREAM_EDIT_INTERVAL_MS=400
