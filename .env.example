# Copy to .env and fill values. Do not commit .env.

# Telegram credentials
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=""

# Sources
FOLDER_INVITE_LINK=""
EXTRA_SOURCES=[]
SOURCES=[]

# Destination (choose one mode)
DESTINATION=""
BOT_DESTINATION_TOKEN=""
BOT_DESTINATION_CHAT_ID=""

# Codex backend
CODEX_BASE_URL="https://chatgpt.com/backend-api"
CODEX_MODEL="gpt-5.3-codex"
CODEX_ORIGINATOR="pi"
# Optional auth bootstrap for cloud runtimes (Replit, etc.)
# Use ONE of these as a secret:
# TG_USERBOT_AUTH_JSON='{\"access_token\":\"...\",\"refresh_token\":\"...\",\"expires_at\":...}'
# TG_USERBOT_AUTH_JSON_B64='base64_or_base64url_encoded_json'
OPENAI_AUTH_BASE="https://auth.openai.com"
# Optional endpoint overrides (normally leave default):
# OPENAI_AUTH_ENDPOINT="https://auth.openai.com/oauth/authorize"
# OPENAI_TOKEN_ENDPOINT="https://auth.openai.com/oauth/token"
OPENAI_AUTH_ENV_ONLY=true
TG_USERBOT_AUTH_JSON=""
TG_USERBOT_AUTH_JSON_B64=""

# Core behavior
DIGEST_MODE=true
DIGEST_INTERVAL_MINUTES=60
DIGEST_DAILY_TIMES=["00:00"]
DIGEST_QUEUE_CLEAR_INTERVAL_MINUTES=0
DIGEST_QUEUE_CLEAR_INCLUDE_INFLIGHT=true
# Deprecated/ignored (queue clear scheduler disabled in runtime):
# DIGEST_QUEUE_CLEAR_SCOPE="inflight"
DIGEST_DAILY_WINDOW_HOURS=24
DIGEST_DAILY_MAX_POSTS=300
DIGEST_MAX_POSTS=80
DIGEST_MAX_TOKENS=18000
CODEX_MODEL_CONTEXT_TOKENS=200000
DIGEST_CONTEXT_FRACTION=0.75
DIGEST_MIN_POST_LENGTH=12
DIGEST_MAX_LINES=12
DIGEST_PREFER_JSON_OUTPUT=true
OUTPUT_LANGUAGE="English"

# Dedupe and routing
ENABLE_DUPE_DETECTION=true
DUPE_ENABLED=true
DUPE_THRESHOLD=0.87
DUPE_CACHE_SIZE=400
DUPE_HISTORY_HOURS=4
DUPE_MERGE_INSTEAD_OF_SKIP=true
# Keep false to avoid HuggingFace downloads in production.
DUPE_USE_SENTENCE_TRANSFORMERS=false
ENABLE_SEVERITY_ROUTING=true
IMMEDIATE_HIGH=true
DIGEST_IMPORTANCE_SCORING=true
DIGEST_INCLUDE_READ_MORE_LINKS=true
INCLUDE_SOURCE_TAGS=false

# OCR translation for media-only posts
MEDIA_TEXT_OCR_ENABLED=true
MEDIA_TEXT_OCR_VIDEO_ENABLED=true
MEDIA_TEXT_OCR_MIN_CHARS=12
MEDIA_TEXT_OCR_MAX_CHARS=1600
MEDIA_TEXT_OCR_VIDEO_MAX_MB=25

# Breaking
BREAKING_NEWS_KEYWORDS=["breaking","urgent","just now","alert","explosion","strike","airstrike","missile","attack","air raid","drone strike","casualties","killed","intercepted"]
BREAKING_MATCH_THRESHOLD=1
ENABLE_BREAKING_TOPIC_THREADS=true
BREAKING_TOPIC_WINDOW_MINUTES=180
BREAKING_TOPIC_MIN_OVERLAP=2
BREAKING_TOPIC_MIN_RATIO=0.55
BREAKING_TOPIC_FUZZY_RATIO=0.72
BREAKING_TOPIC_CONTINUITY_PREFIX=""
HUMANIZED_VITAL_OPINION_ENABLED=true
HUMANIZED_VITAL_OPINION_PROBABILITY=0.35
HUMANIZED_VITAL_OPINION_MAX_WORDS=20

# Delivery/retry
DIGEST_SEND_DELAY_SECONDS=0.8
DIGEST_SEND_CHUNK_SIZE=3600
DIGEST_RETRY_BASE_SECONDS=30
DIGEST_RETRY_MAX_SECONDS=900
DIGEST_429_THRESHOLD_PER_HOUR=3

# Command
DIGEST_STATUS_COMMAND="/digest_status"
DIGEST_POST_PROCESSORS=[]

# Query assistant mode
QUERY_MODE_ENABLED=true
QUERY_MAX_MESSAGES=50
QUERY_DEFAULT_HOURS_BACK=24
QUERY_WEB_FALLBACK_ENABLED=true
QUERY_WEB_MIN_TELEGRAM_RESULTS=3
QUERY_WEB_MAX_RESULTS=12
QUERY_WEB_MAX_HOURS_BACK=24
QUERY_WEB_REQUIRE_RECENT=true
QUERY_WEB_REQUIRE_MIN_SOURCES=2
QUERY_WEB_ALLOWED_DOMAINS=["reuters.com","apnews.com","bbc.com","aljazeera.com","cnn.com","nytimes.com","washingtonpost.com","bloomberg.com","ft.com","theguardian.com","dw.com","france24.com","aa.com.tr","npr.org"]
QUERY_ALLOWED_CHAT_IDS=[]
QUERY_ALLOWED_PEER_IDS=[]

# Streaming UX
STREAMING_ENABLED=true
STREAM_EDIT_INTERVAL_MS=400
STREAM_MAX_CHARS_PER_EDIT=120

# Web server (Replit/UptimeRobot)
ENABLE_WEB_SERVER=true
WEB_SERVER_HOST="0.0.0.0"
WEB_SERVER_PORT=8080
# In headless deployments, keep process alive on startup errors so /health stays reachable.
HOLD_ON_STARTUP_ERROR=true

# Rendering
ENABLE_HTML_FORMATTING=true
ENABLE_PREMIUM_EMOJI=true
PREMIUM_EMOJI_MAP_FILE="nezami_emoji_map.json"
